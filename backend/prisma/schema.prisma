generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum ShareAccess {
  EDIT
  VIEW
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  forms    Form[]
  groups   Group[]
  blocks   Block[]
  contacts Contact[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  role           Role      @default(EDITOR)
  organizationId String
  // Profile fields edited in the builder's "Manage Users" panel. All optional so
  // existing rows are unaffected; the display `name` stays the source of truth.
  firstName      String?
  lastName       String?
  preferredName  String?
  phone          String?
  mobile         String?
  title          String?
  company        String?
  division       String?
  employeeNumber String?
  costCenter     String?
  timeZone       String?
  language       String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization  Organization   @relation(fields: [organizationId], references: [id])
  ownedForms    Form[]         @relation("owner")
  sharedForms   FormShare[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([organizationId])
  @@index([email])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Form {
  id              String    @id @default(cuid())
  title           String
  description     String?
  schemaEnc       Bytes
  schemaIv        String
  schemaTag       String
  ownerId         String
  organizationId  String
  groupId         String?
  scoringSections Json      @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  owner        User            @relation("owner", fields: [ownerId], references: [id])
  organization Organization    @relation(fields: [organizationId], references: [id])
  group        Group?          @relation(fields: [groupId], references: [id])
  shares       FormShare[]
  roleShares   FormRoleShare[]
  shareLinks   ShareLink[]
  submissions  Submission[]
  auditLogs    AuditLog[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([groupId])
}

model FormShare {
  id     String      @id @default(cuid())
  formId String
  userId String
  access ShareAccess

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([formId, userId])
  @@index([userId])
}

// Form shared with a whole role (e.g. all EDITORs). `role` holds the user Role
// value ("ADMIN" | "EDITOR" | "VIEWER") so it matches User.role directly. Custom
// front-end roles can be stored too, but only built-in roles resolve to users
// server-side (the backend has no concept of custom roles).
model FormRoleShare {
  id     String      @id @default(cuid())
  formId String
  role   String
  access ShareAccess

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, role])
  @@index([formId])
}

model Group {
  id             String   @id @default(cuid())
  name           String
  color          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  forms        Form[]

  @@index([organizationId])
}

model Block {
  id             String   @id @default(cuid())
  name           String
  fieldsJson     Json
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// External recipient (patient / guardian / referrer) the builder's "Contact
// Directory" manages. Used as a delivery target when sharing forms. Org-scoped
// and soft-deleted, mirroring User. `notify` is the delivery channel:
// "email" | "sms" | "both". dob is kept as a plain ISO date string (no TZ math).
model Contact {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  firstName      String?
  lastName       String?
  preferredName  String?
  email          String?
  phone          String?
  mobile         String?
  title          String?
  company        String?
  dob            String?
  mrn            String?
  timeZone       String?
  language       String?
  notify         String    @default("email")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entityId  String?
  meta      Json?
  formId    String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  form Form? @relation(fields: [formId], references: [id])

  @@index([userId])
  @@index([entityId])
  @@index([formId])
}

// Public share link for a form. `token` is the random value in the /f/<token>
// URL. The rendered fillable form HTML is snapshotted and AES-256-GCM encrypted
// at rest (htmlEnc/htmlIv/htmlTag), so a leaked DB snapshot never exposes it.
// kind: "public" = open link (Copy share URL); "single" = per-patient link.
model ShareLink {
  id             String    @id @default(cuid())
  token          String    @unique
  formId         String
  organizationId String
  kind           String    @default("public")
  label          String?
  htmlEnc        Bytes
  htmlIv         String
  htmlTag        String
  expiresAt      DateTime?
  revokedAt      DateTime?
  usedAt         DateTime?
  createdById    String
  createdAt      DateTime  @default(now())

  form        Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([formId])
  @@index([organizationId])
}

// A submitted (filled) form response. Answers are PHI, so the payload is
// AES-256-GCM encrypted at rest (dataEnc/dataIv/dataTag), exactly like the form
// schema. Linked to the share link it came through (if any).
model Submission {
  id             String   @id @default(cuid())
  formId         String
  shareLinkId    String?
  organizationId String
  dataEnc        Bytes
  dataIv         String
  dataTag        String
  createdAt      DateTime @default(now())

  form      Form       @relation(fields: [formId], references: [id], onDelete: Cascade)
  shareLink ShareLink? @relation(fields: [shareLinkId], references: [id])

  @@index([formId])
  @@index([shareLinkId])
}

// Delivery audit for submission notifications (one row per recipient/channel).
// No FK to Submission — submissionId is a soft reference so a purged submission
// never cascades away its delivery history.
model NotificationLog {
  id             String   @id @default(cuid())
  submissionId   String?
  formId         String
  organizationId String
  channel        String // 'email' | 'sms'
  recipient      String // destination address (email) — never PHI
  status         String // 'sent' | 'failed' | 'skipped'
  error          String?
  createdAt      DateTime @default(now())

  @@index([formId])
  @@index([submissionId])
}
