# Database
DATABASE_URL="postgresql://credify:dev_password@localhost:5432/credify"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_ACCESS_SECRET="<64-byte-base64-string>"
JWT_REFRESH_SECRET="<64-byte-base64-string>"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# AES master key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_MASTER_KEY="<32-byte-hex-string>"

# HMAC signing key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET="<32-byte-hex-string>"

# SSO — shared secret with the credify-login app (login.credifyfast.com). MUST equal
# that app's JWT_SECRET so this backend can validate its `credify_token` cookie and
# sign in users via SSO. Leave unset to disable cookie-based SSO (Bearer still works).
CREDIFY_LOGIN_JWT_SECRET="<same-as-credify-login-JWT_SECRET>"
# Optional: extra browser origins allowed for credentialed CORS (comma-separated).
# forms/chrome/login .credifyfast.com + localhost are allowed by default.
SSO_ALLOWED_ORIGINS=""

# App
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# Email delivery (submission notifications). Leave MAIL_PROVIDER/MAIL_API_KEY
# unset to disable sending — the notifier becomes a logged no-op (safe default).
# Requires a verified sending domain (SPF/DKIM/DMARC on credifyfast.com).
MAIL_PROVIDER=""                                   # "resend" to enable
MAIL_API_KEY=""                                    # provider API key (secret)
MAIL_FROM="Credify <notifications@credifyfast.com>"
MAIL_REPLY_TO="support@credifyfast.com"
# Base URL used in notification links (the SSO-gated app).
APP_BASE_URL="https://forms.credifyfast.com"
