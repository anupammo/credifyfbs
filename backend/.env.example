# Database
DATABASE_URL="postgresql://credify:dev_password@localhost:5432/credify"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_ACCESS_SECRET="<64-byte-base64-string>"
JWT_REFRESH_SECRET="<64-byte-base64-string>"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# AES master key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_MASTER_KEY="<32-byte-hex-string>"

# HMAC signing key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET="<32-byte-hex-string>"

# App
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# Public-facing app URL — used to build password-reset links and OAuth redirects.
# Falls back to NEXT_PUBLIC_API_BASE_URL when unset.
APP_URL="http://localhost:3000"

# Email — sender identity used by lib/mail.ts (Resend "from" / log fallback).
MAIL_FROM="Credify <no-reply@credifyfast.com>"
# Resend API key — if set, transactional email is sent via https://api.resend.com/emails.
RESEND_API_KEY=""
# SMTP connection URL — placeholder for an SMTP transport (no client bundled by default).
SMTP_URL=""

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# Must exactly match an Authorized redirect URI in the Google console.
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/oauth/google/callback"

# Microsoft OAuth — register an app at https://portal.azure.com (Azure AD app registrations).
MICROSOFT_OAUTH_CLIENT_ID=""
MICROSOFT_OAUTH_CLIENT_SECRET=""
# Must exactly match a Redirect URI configured on the Azure app registration.
MICROSOFT_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/oauth/microsoft/callback"
