+export const AUTH_COOKIE = 'credify_token';
+
+/**
+ * Options for the session cookie. In production it is scoped to the parent
+ * domain (`.credifyfast.com`) so sibling apps (forms.credifyfast.com,
+ * chrome.credifyfast.com) receive it and can run SSO. `COOKIE_DOMAIN` lets you
+ * override per environment. On localhost the cookie stays host-only.
+ */
+export function cookieOptions(maxAgeSeconds: number) {
+  const prod = process.env.NODE_ENV === 'production';
+  const domain = process.env.COOKIE_DOMAIN || (prod ? '.credifyfast.com' : undefined);
+  return {
+    httpOnly: true,
+    secure: prod,
+    sameSite: 'lax' as const,
+    maxAge: maxAgeSeconds,
+    path: '/',
+    ...(domain ? { domain } : {}),
+  };
+}
+
