{
  "name": "credifyfbs-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright test suite for the Credify Form Builder Chrome extension",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-regression",
    "test:cross-browser": "playwright test --project=cross-browser",
    "test:offline": "playwright test --project=offline",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.0.0"
  }
}
